import pandas as pd
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
import matplotlib.pyplot as plt
from sklearn.metrics import mean_squared_error
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import MinMaxScaler
import plotly.graph_objs as go
import plotly.offline as pyo

# 1. 加载数据
data = pd.read_csv('total_load_actual.csv')

# 2. 检查数据是否包含 NaN
if data.isnull().any().any():
    print("Data contains NaN values. Filling missing values...")
    data = data.fillna(method='ffill')  # 使用前值填充缺失数据

# 3. 将数据列转换为字典格式
data_dict = {}
for col in data.columns:
    data_dict[col] = data[col].tolist()

total_acual_load_list = data_dict['total load actual']

# 4. 归一化数据
scaler = MinMaxScaler(feature_range=(0, 1))
total_acual_load_list_scaled = scaler.fit_transform(np.array(total_acual_load_list).reshape(-1, 1)).flatten()

# 5. 设定序列长度和样本数
seq_length = 24
num_samples = len(total_acual_load_list_scaled) - seq_length

# 6. 初始化输入和输出数据
x_processed = []
y_processed = []
for i in range(num_samples):
    x_processed.append(total_acual_load_list_scaled[i:i+seq_length-1])
    y_processed.append(total_acual_load_list_scaled[i+seq_length])

# 7. 打乱数据
indices = np.arange(len(x_processed))
np.random.shuffle(indices)
x_processed = [x_processed[i] for i in indices]
y_processed = [y_processed[i] for i in indices]

# 8. 转换为Tensor
x_processed_tensor = torch.tensor(x_processed, dtype=torch.float32)
y_processed_tensor = torch.tensor(y_processed, dtype=torch.float32).reshape(-1, 1)

# 9. 数据形状检查：确保 x_processed_tensor 的形状为 (样本数量, 序列长度-1, 输入维度)
x_processed_tensor = x_processed_tensor.unsqueeze(-1)  # 将输入扩展为三维张量 (样本数量, seq_length-1, input_dim)

# 10. 数据划分：80% 训练集，20% 测试集 使用 train_test_split
x_train, x_test, y_train, y_test = train_test_split(x_processed_tensor, y_processed_tensor, test_size=0.2, random_state=42)

# 11. 定义前馈神经网络（BP神经网络）
class MLP(nn.Module):
    def __init__(self, input_dim, hidden_dim, output_dim):
        super(MLP, self).__init__()
        self.fc1 = nn.Linear(input_dim, hidden_dim)  # 第一层，全连接层
        self.fc2 = nn.Linear(hidden_dim, hidden_dim)  # 第二层，全连接层
        self.fc3 = nn.Linear(hidden_dim, output_dim)  # 输出层

    def forward(self, x):
        x = torch.relu(self.fc1(x))  # ReLU激活函数
        x = torch.relu(self.fc2(x))  # ReLU激活函数
        x = self.fc3(x)  # 输出层
        return x

# 12. 定义模型
input_dim = seq_length - 1  # 输入维度（序列长度减去1）
hidden_dim = 16
output_dim = 1
model = MLP(input_dim, hidden_dim, output_dim)

# 13. 定义损失函数和优化器
criterion = nn.MSELoss()
optimizer = optim.Adagrad(model.parameters(), lr=0.001)

# 14. 训练模型
num_epochs = 10000
train_loss = []

for epoch in range(num_epochs):
    model.train()
    optimizer.zero_grad()
    output = model(x_train.squeeze(-1))  # 去掉最后一个维度以适应输入
    loss = criterion(output, y_train)
    loss.backward()
    optimizer.step()
    
    train_loss.append(loss.item())
    if (epoch+1) % (num_epochs//10) == 0:
        print(f'Epoch [{epoch+1}/{num_epochs}], Loss: {loss.item():.4f}')

# 15. 测试模型
model.eval()
with torch.no_grad():
    predicted = model(x_test.squeeze(-1)).cpu().numpy()

# 16. 反归一化预测结果
predicted_original_scale = scaler.inverse_transform(predicted)
y_test_original_scale = scaler.inverse_transform(y_test.cpu().numpy())

# 17. 计算均方误差
# MSE MAE MAPE RMSE R^2 LOG_LOSS sMAPE
mse = mean_squared_error(y_test_original_scale, predicted_original_scale)
mae = np.mean(np.abs(y_test_original_scale - predicted_original_scale))
mape = np.mean(np.abs((y_test_original_scale - predicted_original_scale) / y_test_original_scale)) * 100
rmse = np.sqrt(mse)
r2 = 1 - (np.sum((y_test_original_scale - predicted_original_scale) ** 2) / np.sum((y_test_original_scale - np.mean(y_test_original_scale)) ** 2))
log_loss = np.mean(np.log(1 + np.exp(-(y_test_original_scale * 10 - predicted_original_scale * 10))))
smape = np.mean(2 * np.abs(y_test_original_scale - predicted_original_scale) / (np.abs(y_test_original_scale) + np.abs(predicted_original_scale)))
print(f'Mean Squared Error: {mse:.4f}')
print(f'Mean Absolute Error: {mae:.4f}')
print(f'Mean Absolute Percentage Error: {mape:.4f}%')
print(f'Root Mean Squared Error: {rmse:.4f}')
print(f'R-squared: {r2:.4f}')
print(f'Log Loss: {log_loss:.4f}')
print(f'Symmetric Mean Absolute Percentage Error: {smape:.4f}')
import plotly.graph_objs as go
import plotly.offline as pyo

# 1. 训练损失的交互式可视化
train_loss_fig = go.Figure()

# 添加训练损失曲线
train_loss_fig.add_trace(go.Scatter(
    x=list(range(1, num_epochs + 1)),  # 横坐标是训练的轮数
    y=train_loss,  # 纵坐标是训练过程中的损失
    mode='lines',  # 线形显示
    name='Training Loss',  # 曲线的标签
    line=dict(color='royalblue', width=3, dash='dash'),  # 设置颜色、宽度和虚线样式
    marker=dict(symbol='circle', size=6, color='deepskyblue', line=dict(color='darkblue', width=2))  # 数据点样式
))

# 更新图表的布局
